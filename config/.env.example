# 代理（访问 Pixiv 需要，B站不需要）
# 支持 http/https/socks5 协议，留空则不走代理
PROXY=http://127.0.0.1:7890

# Pixiv 配置
PIXIV_REFRESH_TOKEN=
PIXIV_HOT_TAGS=原神,崩壊：スターレイル,終末地,ゼンレスゾーンゼロ,鳴潮
PIXIV_TAG_SEARCH_LIMIT=10
PIXIV_MAX_IMAGES=9

# 安全检测
NSFW_THRESHOLD=0.7

# 内容审核（阿里云 DashScope）
DASHSCOPE_API_KEY=
QWEN_VL_MODEL=qwen-vl-plus

# 视频参数
VIDEO_RESOLUTION_WIDTH=1080
VIDEO_RESOLUTION_HEIGHT=1920
VIDEO_FPS=30
VIDEO_IMAGE_DURATION=5
VIDEO_TRANSITION_DURATION=1

# Bilibili
BILIBILI_CREDENTIAL_PATH=storage/bilibili_credential.json

# 调度
SCHEDULE_CRON_HOUR=9
SCHEDULE_CRON_MINUTE=0

# 批量发布
DAILY_IMAGE_DYNAMICS=8
DAILY_VIDEO_DYNAMICS=3
PUBLISH_DELAY_MIN=60
IMAGES_PER_DYNAMIC=6

# 日志
LOG_LEVEL=INFO
